<Window x:Class="LEBuildConverter.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LEBuildConverter.WPF"
        xmlns:vm="clr-namespace:LEBuildConverter.WPF.ViewModels"
        mc:Ignorable="d"
        Title="LE Build Converter — lastepochtools → maxroll"
        Height="900" Width="1100"
        MinHeight="600" MinWidth="800"
        Background="#1e1e22">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <vm:ScreenshotPathConverter x:Key="Screenshot" />

        <!-- Base text style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2d7d46" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#389c57" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#555555" />
                    <Setter Property="Foreground" Value="#999999" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3f3f46" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2d2d30" />
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#2d2d30" />
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="BorderBrush" Value="#444" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ════════════════════════ HEADER ════════════════════════ -->
        <Border Grid.Row="0" Background="#252528" Padding="16,12" CornerRadius="4" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="LE Build Converter"
                           FontSize="22" FontWeight="Bold" Foreground="#fa9e3d" />
                <TextBlock Text="Convert lastepochtools.com builds for import into maxroll.gg"
                           FontSize="12" Foreground="#888" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- ════════════════════════ BODY ════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- ─── INPUT STATE ─── -->
            <Grid Visibility="{Binding IsInputState, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="600">
                    <TextBlock Text="Paste a lastepochtools.com planner URL"
                               FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="Example: https://www.lastepochtools.com/planner/BakypDvx"
                               FontSize="11" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,16" />
                    <TextBox Text="{Binding LetUrl, UpdateSourceTrigger=PropertyChanged}"
                             Width="580" Height="34" />
                    <Button Content="Fetch Build"
                            Command="{Binding FetchCommand}"
                            Width="200" Height="40" Margin="0,20,0,0"
                            HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- ─── LOADING STATE ─── -->
            <Grid Visibility="{Binding IsLoadingState, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Fetching build..." FontSize="20" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#888"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Grid>

            <!-- ─── SUMMARY STATE ─── -->
            <ScrollViewer Visibility="{Binding IsSummaryState, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="{Binding HeaderLine}"
                               FontSize="22" FontWeight="Bold" Foreground="#fa9e3d" />
                    <TextBlock Text="{Binding PassivesLine}"
                               FontSize="12" Foreground="#aaa" Margin="0,4,0,8" />

                    <!-- Prominent mastery reminder -->
                    <Border Background="#4a2d00" BorderBrush="#fa9e3d" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Foreground="#fa9e3d" FontWeight="Bold" FontSize="12">
                                <Run Text="⚠" />
                                <Run Text="  IMPORTANT  —  " />
                                <Run Text="BEFORE importing passives into maxroll, manually change the planner's class and mastery to:" />
                            </TextBlock>
                            <TextBlock Text="{Binding HeaderLine}"
                                       FontSize="16" FontWeight="Bold" Foreground="White"
                                       Margin="0,4,0,0" HorizontalAlignment="Center" />
                            <TextBlock Foreground="#ddd" FontSize="11" Margin="0,4,0,0"
                                       TextWrapping="Wrap">
                                Maxroll does not auto-switch class from imported JSON. If the wrong class
                                is selected, passives and skills will silently fail to import.
                            </TextBlock>
                        </StackPanel>
                    </Border>


                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left column: equipment + idols -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Equipment" FontWeight="Bold" FontSize="14"
                                       Foreground="#fa9e3d" Margin="0,0,0,4" />
                            <ListBox ItemsSource="{Binding EquipmentLines}" Height="240" />

                            <TextBlock Text="Idols" FontWeight="Bold" FontSize="14"
                                       Foreground="#fa9e3d" Margin="0,12,0,4" />
                            <ListBox ItemsSource="{Binding IdolLines}" Height="160" />
                        </StackPanel>

                        <!-- Right column: skills + blessings -->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Skills" FontWeight="Bold" FontSize="14"
                                       Foreground="#fa9e3d" Margin="0,0,0,4" />
                            <ListBox ItemsSource="{Binding SkillLines}" Height="160" />

                            <TextBlock Text="Blessings" FontWeight="Bold" FontSize="14"
                                       Foreground="#fa9e3d" Margin="0,12,0,4" />
                            <ListBox ItemsSource="{Binding BlessingLines}" Height="240" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="← Back"
                                Command="{Binding BackToInputCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="140" Height="48" Margin="0,0,12,0"
                                FontSize="14" />
                        <Button Content="Start Import Wizard →"
                                Command="{Binding StartWizardCommand}"
                                Width="260" Height="48"
                                FontSize="15" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- ─── WIZARD STATE ─── -->
            <Grid Visibility="{Binding IsWizardState, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Step header -->
                <Border Grid.Row="0" Background="#252528" Padding="16,12" CornerRadius="4" Margin="0,0,0,12">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentStep.Title}"
                                       FontSize="18" FontWeight="Bold" Foreground="#fa9e3d" />
                            <TextBlock Text="{Binding StepProgressText}"
                                       FontSize="11" Foreground="#888" Margin="0,2,0,0" />
                        </StackPanel>
                        <Button Content="Open maxroll"
                                Command="{Binding OpenMaxrollCommand}"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="140" />
                    </Grid>
                </Border>

                <!-- Step body -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="440" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="{Binding CurrentStep.Instructions}"
                                   TextWrapping="Wrap" FontSize="14" LineHeight="22" />

                        <!-- Copy button + JSON preview -->
                        <Button Content="📋 Copy to Clipboard"
                                Command="{Binding CopyCurrentJsonCommand}"
                                Visibility="{Binding CurrentStep.HasJson, Converter={StaticResource BoolToVis}}"
                                Width="240" Height="44" Margin="0,16,0,8"
                                HorizontalAlignment="Left" FontSize="14" />

                        <TextBox Text="{Binding CurrentStep.JsonToCopy, Mode=OneWay}"
                                 Visibility="{Binding CurrentStep.HasJson, Converter={StaticResource BoolToVis}}"
                                 IsReadOnly="True"
                                 Height="160"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="10"
                                 FontFamily="Consolas" />

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#8c8" Margin="0,8,0,0" FontSize="12" />
                    </StackPanel>

                    <!-- Screenshot -->
                    <Border Grid.Column="1" Background="#2d2d30" CornerRadius="4"
                            BorderBrush="#555" BorderThickness="1" Padding="4">
                        <Grid>
                            <!-- Fallback placeholder (shown when image missing) -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="📸" FontSize="48" HorizontalAlignment="Center"
                                           Foreground="#555" />
                                <TextBlock Text="{Binding CurrentStep.ScreenshotName}"
                                           FontSize="10" Foreground="#555" FontFamily="Consolas"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>
                            <!-- Actual screenshot — hides placeholder when loaded -->
                            <Image Source="{Binding CurrentStep.ScreenshotName, Converter={StaticResource Screenshot}}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Step navigation -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="← Back"
                                Command="{Binding PreviousStepCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="100" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Exit to Summary"
                                Command="{Binding StartWizardCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="140" Margin="0,0,8,0"
                                Visibility="Collapsed" />
                        <Button Content="{Binding NextButtonText}"
                                Command="{Binding NextStepCommand}"
                                Width="120" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ─── DONE STATE ─── -->
            <ScrollViewer Visibility="{Binding IsDoneState, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="640" Margin="0,20,0,20">
                    <TextBlock Text="✓" FontSize="64" Foreground="#4ade80"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Build imported!"
                               FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"
                               Margin="0,8,0,0" />

                    <!-- SAVE reminder banner -->
                    <Border Background="#4a2d00" BorderBrush="#fa9e3d" BorderThickness="1"
                            CornerRadius="4" Padding="12,10" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Foreground="#fa9e3d" FontWeight="Bold" FontSize="13"
                                       HorizontalAlignment="Center">
                                <Run Text="⚠ DON'T FORGET TO SAVE" />
                            </TextBlock>
                            <TextBlock Foreground="#ddd" FontSize="12" Margin="0,6,0,0"
                                       TextWrapping="Wrap" TextAlignment="Center">
                                In maxroll's planner, click the save icon (top right) to persist this build
                                to your account. If you close the tab without saving, the build is lost.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               FontSize="13" Foreground="#aaa" Margin="0,16,0,0">
                        After saving, you'll get a shareable maxroll planner URL. If you have Ash's Last Epoch Mods
                        (LE_hud) installed, paste that URL into its gear spawner to load this build in-game
                        instantly.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                        <Button Content="Convert Another Build"
                                Command="{Binding RestartCommand}"
                                Width="220" Height="44" />
                    </StackPanel>

                    <!-- Credits -->
                    <Border Background="#252528" BorderBrush="#3a3a3e" BorderThickness="1"
                            CornerRadius="4" Padding="16,12" Margin="0,32,0,0">
                        <StackPanel>
                            <TextBlock Text="Credits" FontSize="13" FontWeight="Bold"
                                       Foreground="#fa9e3d" Margin="0,0,0,8" />

                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#aaa" LineHeight="17">
                                <Run FontWeight="Bold" Foreground="#e0e0e0" Text="Thanks to Frozen Sentinel" />
                                <Run Text=" — their Runemaster build was published simultaneously to both lastepochtools.com and maxroll.gg, and we used that paired build as our " />
                                <Run FontWeight="Bold" Foreground="#fa9e3d" Text="Rosetta Stone" />
                                <Run Text=" to compare the two planner formats side-by-side. Diffing the raw JSON exports confirmed that lastepochtools' lz-string-encoded item/affix IDs decode to the exact same game-internal integers maxroll uses — and having that paired reference made the whole conversion process far easier to figure out." />
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#aaa" LineHeight="17" Margin="0,12,0,0">
                                <Run FontWeight="Bold" Foreground="#e0e0e0" Text="Thanks to BinaQc" />
                                <Run Text=" and the maxroll team — the loot filter system they built for this season is the reason this tool exists at all. I kept wanting to pull builds from lastepochtools into maxroll just to use their loot filters, and after doing it manually one too many times, I finally built this thing. The maxroll loot filters are the best in the game. Go check them out." />
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#aaa" LineHeight="17" Margin="0,12,0,0">
                                <Run FontWeight="Bold" Foreground="#e0e0e0" Text="AaronActionRPG is cool" />
                                <Run Text=" — he did nothing to help with this tool, but he's a staple of the Last Epoch content creator community and I figured I'd shout him out anyway." />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Disclaimer -->
                    <Border Background="#1e1e22" BorderBrush="#3a3a3e" BorderThickness="1"
                            CornerRadius="4" Padding="16,12" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Disclaimer" FontSize="13" FontWeight="Bold"
                                       Foreground="#888" Margin="0,0,0,8" />
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#888" LineHeight="17">
                                <Run Text="This is a free, non-commercial community tool made by a Last Epoch player who just wanted an easier way to move builds between planners so he could use maxroll's loot filters." />
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#888" LineHeight="17" Margin="0,8,0,0">
                                <Run FontWeight="Bold" Text="LE Build Converter is not affiliated with, endorsed by, or sponsored by" />
                                <Run Text=" Eleventh Hour Games, lastepochtools.com, or maxroll.gg. All item, skill, affix, and passive data is the property of Eleventh Hour Games. Planner format credit goes to lastepochtools.com and maxroll.gg respectively." />
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#888" LineHeight="17" Margin="0,8,0,0">
                                <Run Text="No ads. No analytics. No user data collected. No monetization of any kind. The tool is open source (MIT license) so anyone can verify exactly what it does." />
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#888" LineHeight="17" Margin="0,8,0,0">
                                <Run Text="If lastepochtools, maxroll, or EHG would like this tool taken down or modified, please open an issue on the GitHub repo and I will comply promptly. This tool exists because I love the Last Epoch community and want to make it easier for players to share and test builds — not to harm or compete with anyone." />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <!-- ════════════════════════ FOOTER ════════════════════════ -->
        <Border Grid.Row="2" Background="#252528" Padding="12,6" CornerRadius="4" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" FontSize="11" Foreground="#666" VerticalAlignment="Center">
                    <Run Text="LE Build Converter v1.0.1" />
                    <Run Text="  •  " />
                    <Run Text="{Binding StatusMessage, Mode=OneWay}" Foreground="#8c8" />
                </TextBlock>

                <TextBlock Grid.Column="2" FontSize="10" Foreground="#555" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                    Free community tool. Not affiliated with lastepochtools.com, maxroll.gg, or Eleventh Hour Games. Open source (MIT).
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
